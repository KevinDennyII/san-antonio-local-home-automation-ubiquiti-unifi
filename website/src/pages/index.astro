---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import ArchitectureDiagram from '../components/ArchitectureDiagram.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const features = [
  {
    icon: 'shield' as const,
    title: 'Security-first networking',
    body: 'AI made hacking faster. Consumer routers often have known weak spots. Ubiquiti UniFi gives you control and a cleaner, more secure setup.',
  },
  {
    icon: 'wifi' as const,
    title: 'Strong whole-home Wi‑Fi',
    body: 'Dream Machine Pro plus U6/U7 access points and mesh where needed — segmented for family, guests, and smart devices.',
  },
  {
    icon: 'home' as const,
    title: 'Local Home Assistant',
    body: 'Your own local AI and smart-home brain on a premium mini PC — not locked to Amazon’s cloud.',
  },
  {
    icon: 'mic' as const,
    title: 'Private voice',
    body: 'FutureProofHomes Satellite1 with your own wake word. Alexa or Siri can stay as a convenience only.',
  },
  {
    icon: 'cloud-off' as const,
    title: 'Cloud-outage proof',
    body: 'If Amazon has a bad day, essential automations and local voice can keep working on your network.',
  },
  {
    icon: 'cpu' as const,
    title: 'Premium hardware',
    body: 'Solid mini PC for Home Assistant — not a Raspberry Pi hobby box. Quiet, reliable, professional.',
  },
];
---

<BaseLayout title="Home" description="Private home networking with Ubiquiti UniFi and local Home Assistant for San Antonio homes.">
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <img src={`${base}/images/hero-estate.jpg`} alt="" />
      <div class="hero-scrim"></div>
    </div>
    <div class="container hero-content">
      <p class="eyebrow"><Icon name="lock" size={14} /> Private Home Network</p>
      <h1>Your network. Your local AI. Under your roof.</h1>
      <p class="hero-lead">
        Ubiquiti UniFi for better, more convenient, efficient, and secure Wi‑Fi — plus Home Assistant for a smart home that doesn’t depend on someone else’s cloud.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={`${base}/pilot`}>
          Share the pilot plan <Icon name="share" size={16} />
        </a>
        <a class="btn btn-ghost" href={`${base}/brochure`}>Print brochure</a>
      </div>
      <p class="hero-price">Pilot typically ~$5,000 <span>($4,000–$5,500)</span></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Why this exists</p>
      <h2 class="section-title">Built for control in an AI-hacking world</h2>
      <p class="section-lead">
        Everyday routers like Linksys often have known configuration exploits. We move homes onto UniFi and a fully local Home Assistant stack — the same reason we use this gear ourselves.
      </p>
      <div class="card-grid">
        {
          features.map((f) => (
            <article class="feature-card">
              <div class="icon-wrap">
                <Icon name={f.icon} />
              </div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section diagram-section">
    <div class="container">
      <p class="eyebrow">System map</p>
      <h2 class="section-title">What’s in the pilot</h2>
      <p class="section-lead">
        Confirmed scope: UniFi gateway + Wi‑Fi, Home Assistant on a mini PC, Satellite1 private voice. Cameras and doorbells come later when scoped.
      </p>
      <div class="diagram-wrap">
        <ArchitectureDiagram />
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container cta-panel">
      <div>
        <p class="eyebrow">For partners</p>
        <h2 class="section-title">One link for your realtor</h2>
        <p class="section-lead" style="margin:0;">
          Send the Pilot plan page — plain language, price band, roles, and the one-breath pitch. Keep All docs for your own playbooks and checklists.
        </p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-primary" href={`${base}/pilot`}>Open pilot plan</a>
        <a class="btn btn-ghost" href={`${base}/docs/pilot-plan`}>Same content in docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: min(88vh, 760px);
    display: grid;
    align-items: end;
    color: var(--paper);
    overflow: hidden;
  }

  .hero-media {
    position: absolute;
    inset: 0;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(26, 22, 18, 0.25) 0%, rgba(26, 22, 18, 0.55) 45%, rgba(26, 22, 18, 0.88) 100%),
      linear-gradient(90deg, rgba(26, 22, 18, 0.45), transparent 55%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 5.5rem 0 3.5rem;
    max-width: 40rem;
    margin-left: max(1rem, calc((100% - var(--max)) / 2));
    margin-right: auto;
    width: min(100% - 2rem, 40rem);
  }

  .hero .eyebrow {
    color: var(--copper-bright);
  }

  .hero h1 {
    color: #f7f3ec;
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    margin: 0.6rem 0 1rem;
    max-width: 14ch;
  }

  .hero-lead {
    color: rgba(247, 243, 236, 0.88);
    font-size: 1.08rem;
    max-width: 34rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.5rem 0 1rem;
  }

  .hero .btn-ghost {
    border-color: rgba(247, 243, 236, 0.35);
    color: #f7f3ec;
  }

  .hero .btn-ghost:hover {
    border-color: var(--copper-bright);
    color: white;
  }

  .hero-price {
    margin: 0;
    font-size: 0.92rem;
    color: rgba(247, 243, 236, 0.75);
  }

  .hero-price span {
    opacity: 0.8;
  }

  .diagram-wrap {
    margin-top: 2rem;
  }

  .cta-panel {
    display: grid;
    gap: 1.5rem;
    align-items: center;
    padding: 2rem;
    border-radius: calc(var(--radius) + 4px);
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.55);
    box-shadow: var(--shadow);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (min-width: 800px) {
    .cta-panel {
      grid-template-columns: 1.4fr auto;
    }
  }
</style>
